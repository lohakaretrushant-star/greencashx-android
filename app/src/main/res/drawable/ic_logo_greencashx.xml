    <path android:fillColor="#D94F10" android:pathData="M56,94 L69,88 L67,84 Z"/>

    <!-- RING — 3 arc segments colour-graded, open at bottom for solar panel -->
    <!-- Left arc: orange-red -->
    <path
        android:pathData="M 65,102 A 38,38 0 0 1 62,65 A 38,38 0 0 1 100,27"
        android:strokeColor="#E05A14"
        android:strokeWidth="10"
        android:fillColor="@android:color/transparent"
        android:strokeLineCap="round"/>
    <!-- Top arc: orange -->
    <path
        android:pathData="M 100,27 A 38,38 0 0 1 138,65"
        android:strokeColor="#F0890A"
        android:strokeWidth="10"
        android:fillColor="@android:color/transparent"
        android:strokeLineCap="round"/>
    <!-- Right arc: yellow-gold, shorter — ends before panel -->
    <path
        android:pathData="M 138,65 A 38,38 0 0 1 133,96"
        android:strokeColor="#F5C200"
        android:strokeWidth="10"
        android:fillColor="@android:color/transparent"
        android:strokeLineCap="round"/>

    <!-- SOLAR PANEL — curved navy rectangle sitting at bottom of ring -->
    <!-- Main panel fill -->
    <path
        android:pathData="M 66,100 Q 65,122 100,127 Q 135,122 134,100 Q 117,110 100,111 Q 83,110 66,100 Z"
        android:fillColor="#1A2873"/>
    <!-- Horizontal cell lines -->
    <path android:pathData="M 68,107 Q 100,116 132,107" android:strokeColor="#3352C1" android:strokeWidth="1.2" android:fillColor="@android:color/transparent"/>
    <path android:pathData="M 70,114 Q 100,122 130,114" android:strokeColor="#3352C1" android:strokeWidth="1.2" android:fillColor="@android:color/transparent"/>
    <path android:pathData="M 74,120 Q 100,126 126,120" android:strokeColor="#3352C1" android:strokeWidth="1.2" android:fillColor="@android:color/transparent"/>
    <!-- Vertical cell lines -->
    <path android:pathData="M 80,101 L 76,126" android:strokeColor="#3352C1" android:strokeWidth="1.2" android:fillColor="@android:color/transparent"/>
    <path android:pathData="M 91,103 L 89,127" android:strokeColor="#3352C1" android:strokeWidth="1.2" android:fillColor="@android:color/transparent"/>
    <path android:pathData="M 100,104 L 100,128" android:strokeColor="#3352C1" android:strokeWidth="1.2" android:fillColor="@android:color/transparent"/>
    <path android:pathData="M 109,103 L 111,127" android:strokeColor="#3352C1" android:strokeWidth="1.2" android:fillColor="@android:color/transparent"/>
    <path android:pathData="M 120,101 L 124,126" android:strokeColor="#3352C1" android:strokeWidth="1.2" android:fillColor="@android:color/transparent"/>
    <!-- Panel top-edge highlight (lighter blue strip) -->
    <path
        android:pathData="M 66,100 Q 83,110 100,111 Q 117,110 134,100"
        android:strokeColor="#4A6AE0"
        android:strokeWidth="2.5"
        android:fillColor="@android:color/transparent"
        android:strokeLineCap="round"/>

</vector>
