    <!-- Top-right rays -->
    <path android:fillColor="#FFC107" android:pathData="M122,8 L117,25 L113,22 Z"/>
    <path android:fillColor="#FFA726" android:pathData="M140,18 L130,32 L126,28 Z"/>
    <!-- Right rays -->
    <path android:fillColor="#F07800" android:pathData="M153,36 L140,44 L139,40 Z"/>
    <path android:fillColor="#E86A00" android:pathData="M158,56 L143,58 L144,54 Z"/>
    <!-- Bottom-right rays (smaller, darker) -->
    <path android:fillColor="#E05A14" android:pathData="M153,76 L139,73 L140,69 Z"/>
    <path android:fillColor="#D94F10" android:pathData="M144,94 L131,88 L133,84 Z"/>
    <!-- Top-left rays -->
    <path android:fillColor="#FFC107" android:pathData="M78,8 L83,25 L87,22 Z"/>
    <path android:fillColor="#FFA726" android:pathData="M60,18 L70,32 L74,28 Z"/>
    <!-- Left rays -->
    <path android:fillColor="#F07800" android:pathData="M47,36 L60,44 L61,40 Z"/>
    <path android:fillColor="#E86A00" android:pathData="M42,56 L57,58 L56,54 Z"/>
